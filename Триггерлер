--1. Лог-триггер
CREATE OR REPLACE FUNCTION log_menu_changes() RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO Audit_Log (table_name, operation, old_data, new_data, changed_by)
    VALUES ('Menu', TG_OP, to_jsonb(OLD), to_jsonb(NEW), current_user);
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_menu_audit
AFTER UPDATE OR DELETE ON Menu
FOR EACH ROW EXECUTE FUNCTION log_menu_changes();

--2. Оператор деңгейіндегі триггер
CREATE OR REPLACE FUNCTION prevent_menu_delete() RETURNS TRIGGER AS $$
BEGIN
    IF to_char(now(), 'DY') IN ('SAT', 'SUN') THEN
        RAISE EXCEPTION 'Демалыс күндері мәзірді өшіруге болмайды!';
    END IF;
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_prevent_delete
BEFORE DELETE ON Menu
FOR EACH STATEMENT EXECUTE FUNCTION prevent_menu_delete();


